# 텍스트 파일은 Git 저장소에 LF 기준으로 정규화
* text=auto

# 주요 소스/설정 파일은 LF로 고정
*.java text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.gradle text eol=lf
*.md text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Gradle wrapper 실행 스크립트는 Linux/EC2 실행을 위해 LF 필수
/gradlew text eol=lf

# Linux/EC2에서 실행될 수 있는 쉘 스크립트는 LF 필수
*.sh text eol=lf

# Windows 실행 스크립트는 CRLF 유지
*.bat text eol=crlf
*.cmd text eol=crlf

# 바이너리 파일은 줄바꿈 변환 금지
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary